# this is a comment
echo Example message

var foo=bar
echo The value of foo is $(foo)

if $(foo) == baz
echo Somehow foo is equal to baz!
elif $(foo) == bzz
echo This shouldnt be printed!
else
echo Probably right
endif

echo
echo Lets now print the path env variable: $(PATH)
echo And see our home: $(HOME)
echo

echo Maybe even see the contents of our config file
cat ~/.config/tasosh/tasosh.conf